{
  "name": "ai-based-mobile-network-intrusion-detection",
  "version": "1.0.0",
  "description": "A local 5G IDS research dashboard with bundled ML models, PCAP analysis, VirusTotal enrichment, and optional DeepSeek assistant.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartboy223/AI-Based-Mobile-Network-Intrusion-Detection.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "start": "node backend/server.js",
    "start:ml": "python backend/inference_server.py",
    "start:all": "concurrently -k \"npm run start:ml\" \"node backend/server.js\"",
    "ml:build": "python backend/retrain_pipeline.py"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "js-md5": "^0.8.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/js-md5": "^0.8.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "jszip": "^3.10.1",
    "playwright": "^1.59.1",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0"
  }
}
