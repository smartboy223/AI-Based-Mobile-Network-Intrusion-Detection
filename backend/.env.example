# Backend Configuration for AI-Based Mobile Network Intrusion Detection
# This file holds sensitive configuration for the backend services
#
# HOW TO USE:
# 1. Copy this file: .env.example → .env
# 2. Replace placeholder values with your actual configuration
# 3. Never commit .env to git (it contains secrets!)

# ===============================================================================
# DEEPSEEK LLM CONFIGURATION
# ===============================================================================

# DeepSeek API key (optional, for in-dashboard chat + RAG)
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ===============================================================================
# VIRUSTOTAL API CONFIGURATION
# ===============================================================================

# VirusTotal API Key (optional, but recommended)
# Get your free API key at: https://www.virustotal.com/
# Without this key: System works using 41 hardcoded malicious IPs
# With this key: Adds IP reputation checking from VirusTotal
VIRUSTOTAL_API_KEY=YOUR_API_KEY_HERE

# VirusTotal Rate Limiting (milliseconds between requests)
# Default: 15000 (15 seconds - safe for free tier which allows ~4 requests/minute)
# Minimum: 1000 (1 second)
# Note: Free tier limits to ~4 requests per minute
# Note: Paid tier allows higher rates (up to 500 requests/day)
VIRUSTOTAL_MIN_INTERVAL_MS=15000

# ===============================================================================
# APPLICATION PORTS
# ===============================================================================

# Web Server Port (Express - serves React dashboard)
# Default: 5003
# Change if port 5003 is already in use on your system
MNIDS_PORT=5003

# ML Service Port (FastAPI - runs inference)
# Default: 8787
ML_SERVER_PORT=8787

# ===============================================================================
# ML SERVICE CONFIGURATION
# ===============================================================================

# ML Server URL (for frontend API calls)
# Default: http://127.0.0.1:8787
ML_SERVER_URL=http://127.0.0.1:8787

# ===============================================================================
# DEBUG & LOGGING
# ===============================================================================

# Node.js Environment (production | development)
NODE_ENV=production

# Enable detailed logging (true | false)
DEBUG=false

# ===============================================================================
# EXAMPLES
# ===============================================================================

# Example 1: Minimal (default - works without any keys)
# VIRUSTOTAL_API_KEY=
# VIRUSTOTAL_MIN_INTERVAL_MS=15000

# Example 2: With VirusTotal API
# VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
# VIRUSTOTAL_MIN_INTERVAL_MS=15000

# Example 3: Custom ports
# MNIDS_PORT=8080
# ML_SERVER_PORT=8788

# ===============================================================================
